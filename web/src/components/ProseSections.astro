---
export interface Section {
	heading: string;
	body: string[];
}

interface Props {
	sections: Section[];
}

const { sections } = Astro.props;
---

<div class="prose-blocks section__inner">
	{
		sections.map((s) => (
			<section class="prose-block">
				<h2 class="prose-block__h">{s.heading}</h2>
				{s.body.map((p) => (
					<p>{p}</p>
				))}
			</section>
		))
	}
</div>

<style>
	.prose-blocks {
		padding: 0 var(--space-md) var(--space-2xl);
		max-width: 54rem;
	}

	.prose-block {
		margin-bottom: var(--space-xl);
	}

	.prose-block__h {
		margin: 0 0 var(--space-md);
		font-size: clamp(1.5rem, 3vw, 2.1rem);
		color: var(--color-ink);
	}

	.prose-block p {
		margin: 0 0 var(--space-md);
		font-weight: 300;
		line-height: 1.82;
		color: var(--color-ink);
	}

	.prose-block:first-child p:first-of-type::first-letter {
		font-family: var(--font-display);
		font-size: 3.3rem;
		line-height: 0.85;
		float: left;
		margin-right: 0.35rem;
		color: var(--color-accent);
	}
</style>
