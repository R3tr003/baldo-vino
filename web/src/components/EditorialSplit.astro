---
interface Props {
	kicker: string;
	title: string;
	body: string;
	href: string;
	linkLabel: string;
	image: string;
	imageAlt: string;
	reverse?: boolean;
	tone?: 'light' | 'dark';
}

const {
	kicker,
	title,
	body,
	href,
	linkLabel,
	image,
	imageAlt,
	reverse = false,
	tone = 'light',
} = Astro.props;
---

<section class:list={['editorial', `editorial--${tone}`, { 'editorial--reverse': reverse }]}>
	<div class:list={['editorial__visual', reverse ? 'reveal--right' : 'reveal--left']}>
		<img src={image} alt={imageAlt} width="1600" height="1060" loading="lazy" />
	</div>
	<div class:list={['editorial__copy', reverse ? 'reveal--left' : 'reveal--right']}>
		<div class="editorial-line" aria-hidden="true"></div>
		<p class="editorial__kicker">{kicker}</p>
		<h2 class="editorial__title">{title}</h2>
		<p class="editorial__body">{body}</p>
		<a class:list={['btn', { 'btn--primary': tone === 'dark' }]} href={href}>{linkLabel}</a>
	</div>
</section>

<style>
	.editorial {
		display: grid;
		grid-template-columns: 1fr;
		background: var(--color-paper);
	}

	.editorial--dark {
		background: var(--color-bg-dark);
		color: #f0e8dc;
	}

	.editorial__visual {
		position: relative;
		overflow: hidden;
	}

	.editorial__visual img {
		width: 100%;
		height: 100%;
		min-height: 340px;
		max-height: 680px;
		object-fit: cover;
		transition: transform 0.6s var(--ease-out);
	}

	.editorial__visual:hover img {
		transform: scale(1.02);
	}

	.editorial__copy {
		padding: clamp(1.5rem, 4vw, 5rem);
		align-self: center;
		max-width: 760px;
	}

	.editorial__kicker {
		margin: 0 0 var(--space-sm);
		font-size: 0.72rem;
		font-weight: 500;
		letter-spacing: 0.15em;
		text-transform: uppercase;
		color: var(--color-ink-muted);
	}

	.editorial--dark .editorial__kicker {
		color: var(--color-dark-text-muted);
	}

	.editorial--dark .editorial-line {
		background: rgba(240, 232, 220, 0.25);
	}

	.editorial__title {
		margin: 0 0 var(--space-md);
		font-size: clamp(2rem, 4.4vw, 3.6rem);
	}

	.editorial__body {
		margin: 0 0 var(--space-md);
		max-width: 48ch;
		font-weight: 300;
		line-height: 1.78;
	}

	@media (min-width: 980px) {
		.editorial {
			grid-template-columns: 1.1fr 0.9fr;
		}

		.editorial--reverse {
			grid-template-columns: 0.9fr 1.1fr;
		}

		.editorial--reverse .editorial__visual {
			order: 2;
		}

		.editorial--reverse .editorial__copy {
			order: 1;
			margin-left: auto;
		}
	}
</style>
