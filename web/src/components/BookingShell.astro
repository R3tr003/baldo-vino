---
const lunchSlots = ['12:30', '12:45', '13:00', '13:15', '13:30', '13:45', '14:00', '14:15', '14:30'];
const dinnerSlots = ['19:30', '19:45', '20:00', '20:15', '20:30', '20:45', '21:00', '21:15', '21:30', '21:45', '22:00'];
---

<section class="booking section reveal" id="prenota" aria-labelledby="prenota-heading">
	<div class="section__inner booking__shell">
		<div class="booking__intro">
			<h2 class="booking__title" id="prenota-heading">Prenota un tavolo</h2>
			<p class="booking__lead">
				Modulo in fase di attivazione: nel prossimo step verra' collegato al motore prenotazioni ufficiale.
			</p>
		</div>
		<details class="booking__panel">
			<summary>
				<span>Apri il pannello prenotazione</span>
				<span class="booking__summary-note">Baldo Vino · Bibendum</span>
			</summary>
			<form class="booking__form" action="#" method="post">
			<div class="booking__row">
				<label class="booking__label" for="venue">Locale</label>
				<select class="booking__control" id="venue" name="venue">
					<option value="baldo">Baldo Vino — Ristorante</option>
					<option value="bibendum">Bibendum — Bistrot</option>
				</select>
			</div>
			<div class="booking__row">
				<label class="booking__label" for="guests">Persone</label>
				<select class="booking__control" id="guests" name="guests">
					{Array.from({ length: 6 }, (_, i) => (
						<option value={i + 1}>{i + 1} {i === 0 ? 'persona' : 'persone'}</option>
					))}
				</select>
			</div>
			<div class="booking__row">
				<label class="booking__label" for="date">Data</label>
				<input class="booking__control" type="date" id="date" name="date" />
			</div>
			<div class="booking__row booking__row--split">
				<div>
					<span class="booking__label" id="slot-lunch">Pranzo</span>
					<select class="booking__control" name="time_lunch" aria-labelledby="slot-lunch">
						<option value="">—</option>
						{lunchSlots.map((t) => (
							<option value={t}>{t}</option>
						))}
					</select>
				</div>
				<div>
					<span class="booking__label" id="slot-dinner">Cena</span>
					<select class="booking__control" name="time_dinner" aria-labelledby="slot-dinner">
						<option value="">—</option>
						{dinnerSlots.map((t) => (
							<option value={t}>{t}</option>
						))}
					</select>
				</div>
			</div>
			<p class="booking__hint">
				Se l’orario è vicino all’inizio del servizio, vi preghiamo di contattarci telefonicamente.
			</p>
			<label class="booking__check">
				<input type="checkbox" name="privacy" required />
				<span>Ho letto e accetto il trattamento dei dati personali</span>
			</label>
			<button type="button" class="btn btn--primary booking__submit" disabled>
				Richiedi prenotazione
			</button>
			</form>
		</details>
	</div>
</section>

<style>
	.booking {
		scroll-margin-top: calc(var(--header-h) + var(--space-md));
	}

	.booking__shell {
		display: grid;
		gap: var(--space-lg);
	}

	@media (min-width: 980px) {
		.booking__shell {
			grid-template-columns: minmax(280px, 0.65fr) minmax(320px, 1fr);
			align-items: start;
		}
	}

	.booking__title {
		margin: 0 0 var(--space-sm);
		font-size: clamp(2rem, 4vw, 3rem);
	}

	.booking__lead {
		margin: 0 0 var(--space-lg);
		max-width: 34ch;
		color: var(--color-ink-light);
		font-weight: 300;
		font-size: 1rem;
	}

	.booking__panel {
		background: var(--color-paper);
		border: 1px solid var(--color-line-strong);
		border-radius: var(--radius-lg);
		padding: var(--space-sm);
		box-shadow: var(--shadow-soft);
		transition: box-shadow 0.3s var(--ease-out);
	}

	.booking__panel[open] {
		box-shadow: var(--shadow-dramatic);
	}

	.booking__panel summary {
		cursor: pointer;
		display: flex;
		flex-direction: column;
		gap: 0.15rem;
		padding: var(--space-sm) var(--space-md);
		list-style: none;
	}

	.booking__panel summary::-webkit-details-marker {
		display: none;
	}

	.booking__summary-note {
		font-size: 0.74rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--color-ink-muted);
	}

	.booking__form {
		padding: var(--space-lg);
		border-top: 1px solid var(--color-line);
	}

	.booking__row {
		margin-bottom: var(--space-md);
	}

	.booking__row--split {
		display: grid;
		gap: var(--space-md);
	}

	@media (min-width: 480px) {
		.booking__row--split {
			grid-template-columns: 1fr 1fr;
		}
	}

	.booking__label {
		display: block;
		font-family: var(--font-display);
		font-size: 0.85rem;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--color-ink-muted);
		margin-bottom: var(--space-xs);
	}

	.booking__control {
		width: 100%;
		padding: 0.6rem 0.75rem;
		border-radius: var(--radius-sm);
		border: 1px solid var(--color-line-strong);
		background: #fff;
		color: var(--color-ink);
		font-family: inherit;
		font-size: 1rem;
	}

	.booking__hint {
		font-size: 0.9rem;
		color: var(--color-ink-muted);
		margin: 0 0 var(--space-md);
	}

	.booking__check {
		display: flex;
		gap: var(--space-sm);
		align-items: flex-start;
		font-size: 0.9rem;
		margin-bottom: var(--space-md);
		color: var(--color-ink-muted);
	}

	.booking__submit {
		width: 100%;
	}
</style>
