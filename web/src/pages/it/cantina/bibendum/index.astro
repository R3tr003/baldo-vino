---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import PageIntro from '../../../../components/PageIntro.astro';
---

<BaseLayout title="Cantina — Bibendum">
	<main id="main">
		<PageIntro
			title="Cantina Bibendum"
			subtitle="Wine bar"
			lead="Una selezione dinamica, pensata per il ritmo del bistrot: calici, bottiglie e pairing agili ma ricercati."
		/>

		<section class="section__inner details" aria-label="Identita della cantina Bibendum">
			<article>
				<h2>Calice protagonista</h2>
				<p>
					Rotazione frequente per offrire una carta al calice viva, capace di accompagnare aperitivo, cena e
					after dinner.
				</p>
			</article>
			<article>
				<h2>Abbinamenti bistrot</h2>
				<p>
					Selezione orientata alla convivialita': etichette versatili, beva precisa e pairing immediato con la
					cucina Bibendum.
				</p>
			</article>
		</section>

		<div class="section__inner note">
			<p>
				La carta completa verra' finalizzata con aggiornamento editoriale periodico, mantenendo la coerenza con lo
				stile della sala.
			</p>
			<div class="note__actions">
				<a class="btn btn--primary" href="/it/bibendum/bibendum/">Il bistrot</a>
				<a class="btn" href="/it/contatti/contatti/">Contattaci</a>
			</div>
		</div>
	</main>
</BaseLayout>

<style>
	.details {
		padding: 0 var(--space-md) var(--space-lg);
		display: grid;
		gap: var(--space-md);
	}

	@media (min-width: 860px) {
		.details {
			grid-template-columns: 1fr 1fr;
		}
	}

	.details article {
		padding: var(--space-md);
		border: 1px solid var(--color-line);
		border-radius: var(--radius-md);
		background: var(--color-paper);
	}

	.details h2 {
		margin: 0 0 var(--space-sm);
		font-size: 1.4rem;
	}

	.details p {
		margin: 0;
		color: var(--color-ink-muted);
		line-height: 1.75;
	}

	.note {
		padding: 0 var(--space-md) var(--space-2xl);
		max-width: 52rem;
		color: var(--color-ink-muted);
	}

	.note p {
		margin-bottom: var(--space-md);
	}

	.note__actions {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-sm);
	}
</style>
