---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HomeHero from '../../components/HomeHero.astro';
import BookingShell from '../../components/BookingShell.astro';
import EditorialSplit from '../../components/EditorialSplit.astro';
import { home } from '../../data/home';
import { images } from '../../data/assets';
---

<BaseLayout title="Baldo Vino — Enoteca Ristorante Gourmet a Pistoia">
	<main id="main">
		<HomeHero />

		<div class="section-divider" aria-hidden="true"></div>

		<section class="manifesto section reveal" aria-labelledby="manifesto-title">
			<div class="manifesto__inner">
				<p class="kicker">Manifesto</p>
				<h2 id="manifesto-title">{home.heroMantra}</h2>
			</div>
		</section>

		<div class="section-divider" aria-hidden="true"></div>

		<EditorialSplit
			kicker={home.baldoTeaserKicker}
			title={home.baldoTeaserTitle}
			body={home.baldoTeaser}
			href="/it/baldo-vino/baldo-vino/"
			linkLabel="Scopri il ristorante"
			image={images.heroBaldo}
			imageAlt="Sala del ristorante Baldo Vino"
		/>

		<EditorialSplit
			kicker={home.bibendumTeaserKicker}
			title={home.bibendumTeaserTitle}
			body={home.bibendumTeaser}
			href="/it/bibendum/bibendum/"
			linkLabel="Scopri il bistrot"
			image={images.heroBibendum}
			imageAlt="Bibendum bistrot e wine bar"
			reverse={true}
			tone="dark"
		/>

		<section class="section cantina-strip" aria-labelledby="sec-cantina">
			<div class="section__inner cantina-strip__inner">
				<div class="cantina-strip__statement reveal--left">
					<span class="cantina-strip__number" aria-hidden="true">3000+</span>
					<p class="cantina-strip__number-label">etichette selezionate</p>
				</div>
				<div class="cantina-strip__copy reveal--right">
					<p class="kicker">{home.cantinaTitle}</p>
					<h2 class="cantina-strip__title" id="sec-cantina">
						{home.cantinaLead}
					</h2>
					<ul class="cantina-strip__points">
						{home.cantinaPoints.map((point) => (
							<li>{point}</li>
						))}
					</ul>
					<div class="cantina-strip__links">
						<a class="btn" href="/it/cantina/baldo-vino/">Cantina Baldo Vino</a>
						<a class="btn" href="/it/cantina/bibendum/">Cantina Bibendum</a>
					</div>
				</div>
			</div>
		</section>

		<section class="quote-band section" aria-labelledby="sec-quote">
			<div class="quote-band__inner reveal--scale">
				<p class="quote-band__label" id="sec-quote">Parole</p>
				<blockquote>
					<p>{home.quote}</p>
					<footer>— {home.quoteAuthor}</footer>
				</blockquote>
			</div>
		</section>

		<div class="section-divider" aria-hidden="true"></div>

		<section class="events section" aria-labelledby="sec-eventi">
			<div class="section__inner events__inner">
				<div class="events__copy reveal--left">
					<p class="kicker">Eventi</p>
					<h2 id="sec-eventi">{home.eventiTitle}</h2>
					<p>{home.eventiTeaser}</p>
					<a class="btn btn--primary" href="/it/eventi/eventi/">Organizza un evento</a>
				</div>
				<div class="events__visual reveal--right">
					<img src={images.heroInterior} alt="Palazzo Cancellieri" width="1400" height="1000" loading="lazy" />
				</div>
			</div>
		</section>

		<BookingShell />

		<section class="section legal" aria-label="Note legali">
			<div class="section__inner narrow">
				<p class="legal-note">{home.legalNote}</p>
			</div>
		</section>
	</main>
</BaseLayout>

<style>
	/* Manifesto — narrow, centered, breathing */
	.manifesto__inner {
		max-width: 720px;
		margin: 0 auto;
		text-align: center;
		padding: 0 var(--space-md);
	}

	.manifesto h2 {
		margin: 0;
		font-size: clamp(1.85rem, 4vw, 3.2rem);
		line-height: 1.18;
	}

	.narrow {
		max-width: 40rem;
	}

	/* Cantina strip — giant number + copy */
	.cantina-strip {
		background: var(--color-bg-warm);
		border-block: 1px solid var(--color-line);
	}

	.cantina-strip__inner {
		display: grid;
		gap: var(--space-xl);
		align-items: center;
	}

	@media (min-width: 860px) {
		.cantina-strip__inner {
			grid-template-columns: auto 1fr;
		}
	}

	.cantina-strip__statement {
		text-align: center;
	}

	.cantina-strip__number {
		display: block;
		font-family: var(--font-display);
		font-size: clamp(5rem, 14vw, 11rem);
		font-weight: 700;
		line-height: 0.85;
		letter-spacing: -0.02em;
		color: var(--color-accent);
		opacity: 0.18;
	}

	.cantina-strip__number-label {
		margin: var(--space-xs) 0 0;
		font-size: 0.78rem;
		font-weight: 500;
		letter-spacing: 0.13em;
		text-transform: uppercase;
		color: var(--color-ink-muted);
	}

	.cantina-strip__title {
		margin: 0;
		max-width: 34ch;
		font-size: clamp(1.35rem, 2.8vw, 2.15rem);
		line-height: 1.25;
	}

	.cantina-strip__links {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-sm);
		margin-top: var(--space-md);
	}

	.cantina-strip__points {
		list-style: none;
		padding: 0;
		margin: var(--space-md) 0 0;
		display: grid;
		gap: 0.35rem;
	}

	.cantina-strip__points li {
		font-size: 0.93rem;
		font-weight: 300;
		color: var(--color-ink-muted);
		position: relative;
		padding-left: 1.1rem;
	}

	.cantina-strip__points li::before {
		content: '—';
		position: absolute;
		left: 0;
		color: var(--color-accent);
		font-weight: 500;
	}

	/* Quote band — full-bleed dark, edge-to-edge */
	.quote-band {
		background: var(--color-bg-dark);
		color: var(--color-dark-text);
	}

	.quote-band__inner {
		max-width: 800px;
		margin: 0 auto;
		text-align: center;
		padding: 0 var(--space-md);
	}

	.quote-band__label {
		margin: 0 0 var(--space-sm);
		font-size: 0.72rem;
		font-weight: 300;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--color-dark-text-muted);
	}

	.quote-band blockquote {
		margin: 0;
	}

	.quote-band blockquote p {
		margin: 0 0 var(--space-md);
		font-family: var(--font-display);
		font-size: clamp(1.8rem, 4vw, 3.2rem);
		line-height: 1.16;
		font-style: italic;
	}

	.quote-band footer {
		font-size: 0.78rem;
		font-weight: 300;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--color-dark-text-muted);
	}

	/* Events — offset image with overlap */
	.events__inner {
		display: grid;
		gap: var(--space-lg);
		align-items: center;
	}

	@media (min-width: 980px) {
		.events__inner {
			grid-template-columns: 1fr 1.05fr;
		}
	}

	.events__copy h2 {
		margin: 0 0 var(--space-md);
		font-size: clamp(2rem, 4vw, 3rem);
	}

	.events__copy p {
		max-width: 46ch;
		font-weight: 300;
	}

	.events__visual {
		position: relative;
	}

	.events__visual img {
		width: 100%;
		border-radius: var(--radius-lg);
		min-height: 340px;
		object-fit: cover;
		box-shadow: var(--shadow-dramatic);
	}

	@media (min-width: 980px) {
		.events__visual {
			margin-right: calc(-1 * var(--space-lg));
		}
	}

	/* Legal */
	.legal {
		padding-top: var(--space-lg);
		padding-bottom: var(--space-2xl);
	}

	.legal-note {
		margin: 0;
		font-size: 0.8rem;
		font-weight: 300;
		line-height: 1.5;
		color: var(--color-ink-light);
		font-style: italic;
	}
</style>
